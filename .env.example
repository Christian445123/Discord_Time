# ---- Discord Bot ----
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# ---- txAdmin playersDB Quelle(n) ----
# Ein oder mehrere Pfade zur playersDB.json von txAdmin, mit Komma getrennt.
# Standardpfad ist meist: <FXServer-Ordner>/txData/<server-profil>/data/playersDB.json
# Der Bot muss Lesezugriff auf diese Datei(en) haben (lokal oder per Netzlaufwerk).
PLAYERSDB_PATHS=C:/FXServer/txData/default/data/playersDB.json

# Feldname innerhalb eines Spieler-Eintrags, der die Spielzeit enthaelt.
PLAYERSDB_PLAYTIME_FIELD=playTime
# Einheit des Feldes: minutes | seconds | hours
PLAYERSDB_PLAYTIME_UNIT=minutes

# ---- Rollen ----
ROLE_STAMMSPIELER_ID=
ROLE_EHRENMITGLIED_ID=

# Schwellenwerte in Stunden
STAMMSPIELER_HOURS=170
EHRENMITGLIED_HOURS=340

# Wenn true, wird die Stammspieler-Rolle entfernt, sobald jemand Ehrenmitglied wird.
# Wenn false (Standard), behalten Ehrenmitglieder beide Rollen.
EXCLUSIVE_ROLES=false

# ---- Ablauf ----
# Intervall in Minuten, in dem die Spielzeit neu eingelesen und Rollen aktualisiert werden.
# Werte ab 60 werden automatisch auf volle Stunden gerundet (120 = alle 2 Stunden).
SYNC_INTERVAL_MINUTES=120

# Optional: Textkanal-ID, in die eine Zusammenfassung nach jedem Sync gepostet wird.
LOG_CHANNEL_ID=

# Ausfuehrliche Debug-Logs (zeigt z.B. die rohen Felder des ersten Spielers aus der DB)
DEBUG=false

# ---- Webpanel ----
# Wenn true, startet zusaetzlich ein kleines Webpanel mit Discord-Login. Dort
# sieht jeder eingeloggte Nutzer AUSSCHLIESSLICH seine eigene Spielzeit.
WEB_ENABLED=false
WEB_PORT=3000
# Oeffentlich erreichbare Basis-URL des Panels (ohne Slash am Ende). Muss exakt
# mit einer im Discord Developer Portal hinterlegten OAuth2-Redirect-URL
# uebereinstimmen: <WEB_BASE_URL>/auth/callback
WEB_BASE_URL=http://localhost:3000
# Discord Developer Portal -> Applications -> deine App -> OAuth2 -> Client Secret
DISCORD_CLIENT_SECRET=
# Zufaelliger, langer String zum Signieren der Session-Cookies, z.B. per
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` erzeugen.
SESSION_SECRET=
